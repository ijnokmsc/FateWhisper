<Project Sdk="Dalamud.NET.Sdk/15.0.0">
  <PropertyGroup>
    <!-- 国服 XIVLauncherCN 的 Dalamud 安装路径；CI 中由 setup-dalamud 通过 DALAMUD_HOME 环境变量提供；本地回退到国服路径 -->
    <DalamudLibPath Condition=" '$(DALAMUD_HOME)' == '' ">$(appdata)\XIVLauncherCN\addon\Hooks\dev\</DalamudLibPath>
    <DalamudLibPath Condition=" '$(DALAMUD_HOME)' != '' ">$(DALAMUD_HOME)/</DalamudLibPath>
    <AssemblySearchPaths>$(AssemblySearchPaths);$(DalamudLibPath)</AssemblySearchPaths>
    <AssemblyName>FateWhisper</AssemblyName>
    <RootNamespace>FateWhisper</RootNamespace>
    <Version>0.3.4.0</Version>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <Description>FateWhisper — FF14 跨服猎怪+FATE播报插件，基于 SilverDasher 移植。</Description>
    <PackageProjectUrl>https://github.com/ijnokmsc/FateWhisper</PackageProjectUrl>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Edge_tts_sharp" Version="1.1.7" />
    <PackageReference Include="MQTTnet" Version="4.2.1" />
    <AdditionalFiles Include="data\*.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
  <Target Name="DeployToDevPlugins" AfterTargets="Build" Condition=" '$(GITHUB_ACTIONS)' != 'true' ">
    <MakeDir Directories="$(appdata)\XIVLauncherCN\devPlugins\FateWhisper\" />
    <ItemGroup>
      <AllDlls Include="$(OutputPath)*.dll" />
      <AllJson Include="$(OutputPath)*.json" />
      <ManifestJson Include="$(ProjectDir)FateWhisper.json" />
      <DataFiles Include="$(ProjectDir)data\*.json" />
    </ItemGroup>
    <Copy SourceFiles="@(AllDlls)" DestinationFolder="$(appdata)\XIVLauncherCN\devPlugins\FateWhisper\" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(AllJson)" DestinationFolder="$(appdata)\XIVLauncherCN\devPlugins\FateWhisper\" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(ManifestJson)" DestinationFolder="$(appdata)\XIVLauncherCN\devPlugins\FateWhisper\" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(DataFiles)" DestinationFolder="$(appdata)\XIVLauncherCN\devPlugins\FateWhisper\data\" SkipUnchangedFiles="true" />
  </Target>
</Project>
